# Copy this file to .env.local and fill in real values.
# Without these, the inquiry form will still "succeed" but the email will only be logged to the console.

# Get a free key at https://resend.com (signup → API Keys)
RESEND_API_KEY=

# Where trade inquiries should arrive
TRADE_INBOX=trade@bernardourbina.com

# Optional — must be a verified Resend domain.
# Default 'onboarding@resend.dev' works for testing but goes to spam in production.
TRADE_SENDER=BUD Trade <trade@bernardourbina.com>
